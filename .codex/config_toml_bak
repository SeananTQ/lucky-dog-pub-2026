[mcp_servers.wick]
command = "dotnet"
args = [
    "run",
    "--project",
    "G:/Workspace/godot-project/lucky-dog-pub-2026/wick-mcp-server/Wick/src/Wick.Server",
    "--no-build",
    "--configuration",
    "Release"
]

[mcp_servers.wick.env]
WICK_GROUPS = "all"
WICK_GODOT_BIN = "G:/MyProgram/GodotCom/Godot_v4.6.3/Godot_v4.6.3-stable_mono_win64.exe"
WICK_PROJECT_PATH = "G:/Workspace/godot-project/lucky-dog-pub-2026/lucky-dog-rise"

[mcp_servers.wick.tools.scene_get_tree]
approval_mode = "approve"

[mcp_servers.wick.tools.editor_status]
approval_mode = "approve"

[mcp_servers.wick.tools.build_diagnose]
approval_mode = "approve"
