# Steamworks 中大型美术资源由 _stable-git/ 文件夹来管理
lucky-steamworks/assets/**/*.psd
lucky-steamworks/assets/**/*.psb
lucky-steamworks/assets/**/*.png
lucky-steamworks/assets/**/*.jpg
lucky-steamworks/assets/**/*.jpeg
lucky-steamworks/assets/**/*.ico
lucky-steamworks/assets/**/*.ai

# _stable-git 为定期手动复制到该文件夹内的稳定版本的美术资源
!lucky-steamworks/assets/_stable-git/
!lucky-steamworks/assets/_stable-git/**

# key 文件不需要上传到版本控制系统
lucky-steamworks/playtest-key/

# 测试文件夹和外部资源不需要上传到版本控制系统
lucky-steamworks/achievement/tools/steamworks-achievement-sync/test/
lucky-steamworks/achievement/external/
