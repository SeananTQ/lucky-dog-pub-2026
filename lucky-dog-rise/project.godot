; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LuckyDogRise"
run/main_scene="res://Scenes/Main.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1200
window/size/viewport_height=1200

[dotnet]

project/assembly_name="LuckyDogRise"

[autoload]

AudioManager="*res://Scripts/AudioManager.cs"

[editor_plugins]

enabled=PackedStringArray("res://addons/wick/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"

[window]

size/viewport_width=1200
size/viewport_height=1200
size/window_width_override=1200
size/window_height_override=1200
